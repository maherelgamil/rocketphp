{
    "name": "maherelgamil/rocketphp",
    "description": "Filament-style admin panel framework for Inertia.js + React.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "inertia", "react", "admin", "panel", "filament"],
    "authors": [
        {
            "name": "Maher El Gamil",
            "email": "maherelgamil@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0|^13.0",
        "inertiajs/inertia-laravel": "^3.0"
    },
    "support": {
        "issues": "https://github.com/maherelgamil/rocketphp/issues",
        "source": "https://github.com/maherelgamil/rocketphp"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "MaherElGamil\\Rocket\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MaherElGamil\\Rocket\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest"
    },
    "extra": {
        "laravel": {
            "providers": [
                "MaherElGamil\\Rocket\\RocketServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/maherelgamil"
        }
    ]
}
